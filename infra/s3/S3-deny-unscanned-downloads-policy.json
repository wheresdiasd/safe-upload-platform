{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "DenyUnscannedDownloads",
            "Effect": "Deny",
            "Principal": "*",
            "Action": "s3:GetObject",
            "Resource": "arn:aws:s3:::safe-upload-platform-mrfingers/*",
            "Condition": {
                "StringNotEquals": {
                    "s3:ExistingObjectTag/GuardDutyMalwareScanStatus": "NO_THREATS_FOUND"
                }
            }
        }
    ]
}